    {
      "id": "non-api-content",
      "name": "Non-API Content",
      "description": "Non-API resources: images, fonts, media, styles, scripts.",
      "enabledByDefault": true,
      "pathPatterns": [
        "/.well-known/",
        "/favicon.ico",
        "/robots.txt",
        "/sitemap.xml"
      ],
      "contentTypes": [
        "image/*",
        "font/*",
        "video/*",
        "audio/*",
        "text/css",
        "text/html",
        "application/javascript",
        "application/x-javascript",
        "text/javascript",
        "application/wasm"
      ]
    },
    {
      "id": "social",
      "name": "Social & Third-Party Widgets",
